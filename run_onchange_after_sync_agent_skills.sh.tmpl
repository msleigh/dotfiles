#!/usr/bin/env bash

set -euo pipefail

# run_onchange_: chezmoi re-runs this only when its rendered content changes.
# The hashes below fold every managed skill into that content, so adding,
# removing, or editing a skill re-triggers the sync (chezmoi apply is otherwise
# a no-op for skills). Machine-independent: keyed on skill name + SKILL.md hash.
{{ range (glob (joinPath .chezmoi.sourceDir "private_dot_agents" "skills" "*" "SKILL.md")) -}}
# skill: {{ dir . | base }} {{ include . | sha256sum }}
{{ end -}}

readonly HOME_DIR="{{ .chezmoi.destDir }}"
readonly SOURCE_DIR="${HOME_DIR}/.agents/skills"
readonly TARGET_DIRS=(
  "${HOME_DIR}/.claude/skills"
  "${HOME_DIR}/.codex/skills"
  "${HOME_DIR}/.config/agents/skills"
  "${HOME_DIR}/.config/goose/skills"
  "${HOME_DIR}/.config/opencode/skills"
)

warn() {
  printf 'agent-skills: %s\n' "${*}" >&2
}

same_tree() {
  local source="${1}"
  local target="${2}"

  diff -qr "${source}" "${target}" >/dev/null 2>&1
}

# Canonical (symlink-resolved) path of a directory, or empty if it does not
# resolve to a real directory.
real_dir() {
  (cd "${1}" >/dev/null 2>&1 && pwd -P) || true
}

link_skill() {
  local source="${1}"
  local target_dir="${2}"
  local skill_name
  local target

  skill_name="$(basename "${source}")"
  target="${target_dir}/${skill_name}"

  # Never operate on a target directory that resolves to the source directory
  # itself (e.g. a legacy ~/.claude/skills -> ~/.agents/skills symlink). Doing
  # so would make the script delete and self-link its own source skills.
  if [[ -d "${target_dir}" && "$(real_dir "${target_dir}")" == "${SOURCE_REAL}" ]]; then
    warn "${target_dir} resolves to the skills source; skipping to avoid clobbering it."
    return
  fi

  mkdir -p "${target_dir}"

  if [[ -L "${target}" ]]; then
    ln -sfn "${source}" "${target}"
    return
  fi

  if [[ -e "${target}" ]]; then
    # Guard against target and source being the same real path before any
    # destructive rm; only replace a genuinely separate, identical copy.
    if [[ -d "${target}" ]] &&
      [[ "$(real_dir "${target}")" != "${SOURCE_REAL}" ]] &&
      same_tree "${source}" "${target}"; then
      rm -rf "${target}"
      ln -s "${source}" "${target}"
    else
      warn "${target} exists and differs from ${source}; leaving it alone."
    fi
    return
  fi

  ln -s "${source}" "${target}"
}

main() {
  local skill_dir
  local target_dir

  if [[ ! -d "${SOURCE_DIR}" ]]; then
    return
  fi

  # Resolved source path, used by link_skill to refuse to clobber the source.
  SOURCE_REAL="$(real_dir "${SOURCE_DIR}")"
  readonly SOURCE_REAL

  shopt -s nullglob
  for skill_dir in "${SOURCE_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue
    [[ -f "${skill_dir}/SKILL.md" ]] || continue

    for target_dir in "${TARGET_DIRS[@]}"; do
      link_skill "${skill_dir}" "${target_dir}"
    done
  done
}

main "${@}"
