#!/usr/bin/env bash
# plist hash: {{ include "private_Library/private_LaunchAgents/io.msleigh.ollama.plist" | sha256sum }}

set -euo pipefail

readonly LABEL="io.msleigh.ollama"
readonly OLLAMA_BIN="/opt/homebrew/opt/ollama/bin/ollama"

main() {
    local plist="${HOME}/Library/LaunchAgents/${LABEL}.plist"

    [[ "$(uname -s)" == "Darwin" ]] || return 0
    [[ -f "${plist}" ]] || return 0

    if [[ ! -x "${OLLAMA_BIN}" ]]; then
        printf 'reload-ollama: %s not found; skipping.\n' "${OLLAMA_BIN}" >&2
        return 0
    fi

    launchctl bootout "gui/$(id -u)/${LABEL}" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "${plist}"
}

main "${@}"
